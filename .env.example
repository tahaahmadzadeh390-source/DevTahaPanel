# Server Config
PORT=3000
NODE_ENV=production

# JWT Secret
JWT_SECRET=your_super_secret_key_change_this_in_production

# Admin Panel Password (will be hashed)
ADMIN_PASSWORD=admin123

# Database
DB_PATH=./data/panel.db

# Security
API_RATE_LIMIT=100
SESSION_TIMEOUT=3600

# V2Ray Config
V2RAY_PORT=10086
V2RAY_LOG_LEVEL=warning
